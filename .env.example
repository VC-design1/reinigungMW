# Supabase-Projekt-URL und Keys (Settings -> API in deinem Supabase-Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nur serverseitig verwenden (API-Routen, Seed-Skript) — niemals an den Client
# ausliefern oder committen. Wird u.a. gebraucht, um Reinigungskräfte-Accounts
# anzulegen (auth.admin.createUser) und Benachrichtigungen zu schreiben.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web-Push (Browser-Benachrichtigungen). Eigenes Schlüsselpaar erzeugen mit:
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY wird im Client zum Abonnieren verwendet,
# VAPID_PRIVATE_KEY ausschließlich serverseitig zum Versenden.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional: E-Mail-Versand über Resend (https://resend.com). Ohne Key wird
# E-Mail-Versand übersprungen (still no-op) — in-app- und Push-Benachrichtigungen
# funktionieren unabhängig davon weiter.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Reinigungsmanagement <notifications@example.com>

# Geheimer Header-Wert, der Cron-Aufrufe (z.B. Vercel Cron) an /api/cron/*
# authentifiziert — frei wählbarer, langer Zufallswert.
CRON_SECRET=

# Öffentliche Basis-URL der App, nur für Links in E-Mail-Benachrichtigungen.
NEXT_PUBLIC_APP_URL=http://localhost:3000
